# ── Auth (API container uses Docker-internal URLs) ───────────────────────────
AUTH_PROVIDER=keycloak           # keycloak | iam
JWT_ISSUER=http://keycloak:8080/realms/rbac-mlflow
JWT_AUDIENCE=rbac-frontend
JWKS_URI=http://keycloak:8080/realms/rbac-mlflow/protocol/openid-connect/certs

# ── Frontend Auth.js ─────────────────────────────────────────────────────────
AUTH_URL=https://rbac.local
AUTH_SECRET=generate-a-random-32-byte-secret-here
AUTH_TRUST_HOST=1
KEYCLOAK_CLIENT_ID=rbac-frontend
KEYCLOAK_CLIENT_SECRET=dev-secret-change-in-prod
KEYCLOAK_ISSUER=https://keycloak.rbac.local/realms/rbac-mlflow

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=rbac
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres            # default DB (not used directly; init script creates rbac_db etc.)
DATABASE_URL=postgresql+asyncpg://rbac:changeme@postgres:5432/rbac_db

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql://rbac:changeme@postgres:5432/mlflow_db
MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts/mlflow
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ── Artifact store ───────────────────────────────────────────────────────────
ARTIFACT_STORE=minio             # minio | s3
S3_BUCKET=mlflow-artifacts
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── MinIO (local dev only) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Keycloak (local dev only) ─────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Traefik ───────────────────────────────────────────────────────────────────
TRAEFIK_DOMAIN=rbac.local
